meta {
  name: Get Invite Info
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/invites/{{inviteCode}}
  body: none
  auth: none
}

headers {
  Cookie: accessToken={{accessToken}}
}

tests {
  test("returns invite info", function() {
    expect(res.status).to.equal(200);
  });

  test("invite has guild info", function() {
    const body = res.getBody();
    expect(body.guild).to.be.ok;
    expect(body.guild.id).to.be.ok;
    expect(body.code).to.equal(bru.getVar('inviteCode'));
  });
}
