meta {
  name: Create Guild for messaging
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/guilds
  body: json
  auth: none
}

headers {
  Cookie: accessToken={{accessToken}}
}

body:json {
  {
    "name": "Messaging Test Guild"
  }
}

script:post-response {
  if (res.status === 200) {
    const body = res.getBody();
    bru.setVar('guildId', body.id);
  }
}
