meta {
  name: Create text channel
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/channels/guild/{{guildId}}
  body: json
  auth: none
}

headers {
  Cookie: accessToken={{accessToken}}
}

body:json {
  {
    "name": "test-chat",
    "type": 0,
    "position": 0
  }
}

script:post-response {
  if (res.status === 200 || res.status === 201) {
    const body = res.getBody();
    bru.setVar('channelId', body.id);
  }
}
