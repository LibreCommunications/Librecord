meta {
  name: Get channel messages
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/guild-channels/{{channelId}}/messages?limit=50
  body: none
  auth: none
}

headers {
  Cookie: accessToken={{accessToken}}
}

tests {
  test("returns messages", function() {
    expect(res.status).to.equal(200);
  });

  test("response is array with messages", function() {
    const body = res.getBody();
    expect(body).to.be.an('array');
    expect(body.length).to.be.greaterThan(0);
  });
}
