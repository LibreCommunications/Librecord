meta {
  name: Create Guild
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/guilds
  body: json
  auth: none
}

headers {
  Cookie: accessToken={{accessToken}}
}

body:json {
  {
    "name": "Voice Test Guild"
  }
}

script:post-response {
  if (res.status === 200 || res.status === 201) {
    const body = res.getBody();
    bru.setVar('guildId', body.id);
  }
}
