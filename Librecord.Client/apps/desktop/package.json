{
  "name": "@librecord/desktop",
  "version": "0.1.27",
  "private": true,
  "type": "module",
  "description": "Librecord desktop app",
  "author": "LibreCommunications",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite -c electron.vite.config.ts",
    "build": "vite build -c electron.vite.config.ts",
    "package": "electron-builder",
    "package:linux": "electron-builder --linux AppImage",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win"
  },
  "dependencies": {
    "@librecord/api-client": "workspace:*",
    "@librecord/app": "workspace:*",
    "@librecord/design": "workspace:*",
    "@librecord/domain": "workspace:*",
    "@librecord/platform": "workspace:*",
    "@librecord/platform-electron": "workspace:*",
    "@librecord/platform-web": "workspace:*",
    "@librecord/ui-web": "workspace:*",
    "electron-updater": "^6.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6"
  },
  "optionalDependencies": {
    "@librecord/pipecap": "file:../../../../pipecap",
    "@librecord/winaudio": "file:../../../../wincap"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "41.1.1",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.librecord.desktop",
    "productName": "Librecord",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/icons/**/*",
      "package.json",
      "node_modules/pkg-prebuilds/**/*",
      "node_modules/@librecord/pipecap/**/*",
      "node_modules/@librecord/winaudio/**/*"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Network;Chat;InstantMessaging",
      "icon": "build/icons",
      "executableName": "librecord",
      "artifactName": "${productName}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icons/512x512.png",
      "category": "public.app-category.social-networking"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icons/icon.ico",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "LibreCommunications",
      "repo": "Librecord"
    }
  }
}
